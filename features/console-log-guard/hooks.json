{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "__HOME__/.claude/hooks/console-log-guard/check-file.sh"
					}
				]
			}
		],
		"SessionEnd": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "__HOME__/.claude/hooks/console-log-guard/audit-session.sh"
					}
				]
			}
		]
	}
}
