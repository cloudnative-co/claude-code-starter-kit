{
	"hooks": {
		"PreCompact": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "__HOME__/.claude/hooks/memory-persistence/pre-compact.sh"
					}
				]
			}
		],
		"PostCompact": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "__HOME__/.claude/hooks/memory-persistence/post-compact.sh"
					}
				]
			}
		],
		"SessionStart": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "__HOME__/.claude/hooks/memory-persistence/session-start.sh"
					}
				]
			}
		],
		"SessionEnd": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "__HOME__/.claude/hooks/memory-persistence/session-end.sh"
					}
				]
			}
		]
	}
}
